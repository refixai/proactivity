  "navbar": {
    "links": [
      { "label": "GitHub", "href": "https://github.com/refixai/proactivity" }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/refixai/proactivity"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/refixai/proactivity"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  }
}
