{
  "name": "@refixai/proactivity",
  "version": "0.1.0",
  "description": "Proactivity primitives for autonomous agents — scheduling, governance, goals, briefing",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres/index.d.ts",
      "import": "./dist/postgres/index.js"
    },
    "./bullmq": {
      "types": "./dist/bullmq/index.d.ts",
      "import": "./dist/bullmq/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js"
    },
    "./timer": {
      "types": "./dist/timer/index.d.ts",
      "import": "./dist/timer/index.js"
    },
    "./prompts": {
      "types": "./dist/prompts/index.d.ts",
      "import": "./dist/prompts/index.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "pg": ">=8.0.0",
    "bullmq": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.14.0",
    "bullmq": "^5.52.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/refixai/proactivity"
  }
}
