{
  "name": "@refix/proactivity",
  "version": "0.1.0",
  "description": "Proactivity primitives for autonomous agents — scheduling, governance, goals, briefing",
  "type": "module",
  "author": "Refix AI",
  "homepage": "https://github.com/refixai/proactivity#readme",
  "bugs": "https://github.com/refixai/proactivity/issues",
  "keywords": [
    "autonomous-agents",
    "agent",
    "scheduler",
    "proactivity",
    "heartbeat",
    "governance",
    "ai-agents"
  ],
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres/index.d.ts",
      "import": "./dist/postgres/index.js"
    },
    "./bullmq": {
      "types": "./dist/bullmq/index.d.ts",
      "import": "./dist/bullmq/index.js"
    },
    "./timer": {
      "types": "./dist/timer/index.d.ts",
      "import": "./dist/timer/index.js"
    },
    "./prompts": {
      "types": "./dist/prompts/index.d.ts",
      "import": "./dist/prompts/index.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "bullmq": ">=5.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@types/node": "^24",
    "@types/pg": "^8.11.0",
    "bullmq": "^5.52.0",
    "pg": "^8.14.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/refixai/proactivity.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
